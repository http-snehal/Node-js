<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Airbnb | Holiday Rentals, Cabins, Beach Houses & More</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/airbnb/static/output.css" />
</head>
<body class="bg-white text-gray-900 font-sans antialiased">

    <header class="sticky top-0 z-50 bg-white border-b border-gray-200">
        <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-1 text-[#FF385C]">
                <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="currentColor"><path d="M16 1c2.008 0 3.463.963 4.751 3.269l.533 1.025c1.954 3.83 6.114 12.54 7.1 14.836l.145.353c.667 1.591.91 2.472.96 3.396l.01.415.001.228c0 4.062-2.877 6.478-6.357 6.478-2.224 0-4.556-1.258-6.709-3.386l-.257-.26-.172-.179h-.011l-.176.185c-2.044 2.1-4.392 3.415-6.474 3.614l-.54.027c-3.415 0-6.292-2.416-6.292-6.478l.01-.285c.01-.433.102-1.139.63-2.502l.147-.367c.983-2.28 5.114-10.954 7.078-14.808l.543-1.042C12.551 1.963 14.004 1 16 1zm0 2c-1.232 0-2.203.626-3.23 2.46l-.506.97c-1.915 3.712-6.052 12.38-7.014 14.619l-.146.353c-.452 1.082-.544 1.666-.56 2.11l-.004.21c0 2.872 1.942 4.478 4.292 4.478 1.624 0 3.523-1.076 5.37-3.045l.21-.23.18-.198.188-.205 1.401 1.488c2.01 2.022 4.093 3.19 5.8 3.19 2.91 0 4.357-2.11 4.357-4.478l-.004-.21c-.013-.362-.081-.926-.484-2.002l-.146-.353c-.962-2.239-5.111-10.94-7.013-14.618l-.507-.97C18.214 3.626 17.241 3 16 3zm0 9a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"></path></svg>
                <span class="text-xl font-bold tracking-tight">airbnb</span>
            </div>

            <ul class="flex items-center gap-6 text-sm font-semibold">
                <li><a href="/" class="hover:bg-gray-100 px-4 py-2 rounded-full transition">Go to Home</a></li>
                <li>
                    <a href="/host/add-home" class="px-4 py-2 rounded-full border border-gray-300 hover:shadow-md transition">
                        Airbnb your home
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <main class="container mx-auto px-6 py-12">
        <div class="max-w-2xl">
            <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900 mb-4">
                Welcome to <span class="text-[#FF385C]">AirBnb</span>
            </h2>
            <p class="text-lg text-gray-500 mb-8">
                Explore unique homes and experiences around the world.
            </p>
            
            <a href="/host/add-home" 
               class="inline-block bg-[#FF385C] text-white px-8 py-3 rounded-lg font-bold text-lg hover:bg-[#E00B41] transition transform active:scale-95 shadow-lg shadow-rose-200">
                Start Hosting Today
            </a>
        </div>

        <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
            <% if (homeList.length > 0) { %>
                <% homeList.forEach(home => { %>
                    <div class="group cursor-pointer">
                        <div class="aspect-square bg-gray-200 rounded-xl mb-3 overflow-hidden">
                            <img src="<%= home.photoUrl %>" alt="Home Image" 
                                 class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                        </div>
                        <h3 class="font-bold text-gray-900"><%= home.housename %></h3>
                        <p class="text-gray-500 text-sm italic"><%= home.location %></p>
                        <p class="mt-1 font-semibold">$<%= home.price %> <span class="font-normal">night</span></p>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center border-2 border-dashed border-gray-200 rounded-2xl">
                    <p class="text-gray-400 text-lg">No listings available yet. Be the first to add one!</p>
                </div>
            <% } %>
        </div>
        </main>

</body>
</html>